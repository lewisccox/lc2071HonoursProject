AssetBasedSystem
with core::*;
with NPPDomain_def::* from "NPPDomain_def.abs";
with NPPModelTemplate::* from "NPPModel(KHNP).abs";
with BehaviourDefinitions::* from "KHNPBehaviourDefinitions.abs";

AssetGroup KHNPGoals {
	Goal KHNPAttack {
		description "Infect Network"
		pre = 
		CROperator.PhishingEmailReceived == false
		post = 
		KHNPNuclearSecrets.ExistsOnMonitors.contains(KimsukyMonitor)&&
		!KHNPNuclearSecrets.ExistsOnMonitors.contains(ControlRoom)
	}
	Goal Step1 {
		description "Send phishing email"
		pre = //a PC on or connected to the NPP network is infected with stuxnet 
		CROperator.PhishingEmailReceived == false
		post = //other PCs on the network will be infected with stuxnet 
		CROperator.PhishingEmailReceived == true
	}
	
	Goal Step2{
		description "Get Operator to open phishing email"
		pre = 
		CROperator.PhishingEmailReceived == false
		post = 
		CROperator.PhishingEmailOpened == true
	}
	
}