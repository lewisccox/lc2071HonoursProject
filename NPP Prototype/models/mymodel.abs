AssetBasedSystem

// namespace shortcuts    
with core::*; 
with mydomain_def::*;

import "platform:/plugin/core.abs.model.lib/models/core.abs";
import "mydomain_def.abs";

AssetGroup  mymodel {
	
	// list of mymodel assets
	Asset A1 : ConceptA {}
	Asset A2 : ConceptA {}
	Asset B1 : ConceptB {} 
	
	// list of links between mymodel assets
	link A1 to B1  as ConceptA::conceptBs
	link A2 to B1  as ConceptA::conceptBs
}
