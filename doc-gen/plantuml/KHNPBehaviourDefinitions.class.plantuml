@startuml
class IndustrialComponent  {
	ComponentOnline : Boolean
	ComponentCompromised : Boolean
	void SafeGuardsDeactivateCompromisedSystem()
}
class Operator  {
	PhishingEmailReceived : Boolean
	PhishingEmailOpened : Boolean
	Email : String
	TrustedEmails : String
	isHacker : Boolean
	void OperatorOpensPhishingEmail()
	void HackerSendsPhishingEmail()
}
class Actuator  {
	ActuatorOnline : Boolean
	ActuatorCompromised : Boolean
	void ReactorMotorDestroyed()
	void SafeGuardsDeactivateCompromisedSystem()
}
class Sensor  {
	SensorOnline : Boolean
	SensorCompromised : Boolean
}
class NetworkConnector  {
	trafficLevel : Integer
	trafficCapacity : Integer
	ConnectorOnline : Boolean
	NetworkCompromised : Boolean
	void NetworkCompromised()
	void DeviceCompromisesNetwork()
	void MonitorInfectsPLC()
	void HackerSendsPhishingEmail()
}
class Malware  {
	OwnerIP : String
	CompatableSoftwareDate : Integer
	CompatableMonitorOS : String
	CompatablePLCOS : String
	RequiredSoftware : String
	void DeviceCompromisesNetwork()
	void HackerSendsPhishingEmail()
	void OperatorOpensPhishingEmail()
	void MonitorInfectsPLC()
	void NetworkCompromised()
}
class SafeguardSystem  {
	SafeguardOnline : Boolean
	void SafeGuardsDeactivateCompromisedSystem()
}
class NetworkConnector  {
	trafficLevel : Integer
	trafficCapacity : Integer
	ConnectorOnline : Boolean
	NetworkCompromised : Boolean
	void DeviceCompromisesNetwork()
	void HackerSendsPhishingEmail()
	void MonitorInfectsPLC()
	void NetworkCompromised()
}
class PLC  {
	PLCOnline : Boolean
	PLCCompromised : Boolean
	PLCOS : String
	PLCSoftwareRelease : Integer
	PLCInfected : Boolean
	void ReactorMotorDestroyed()
	void MonitorInfectsPLC()
}
class ContainableByAny  {
}
class IndustrialComponent  {
	ComponentOnline : Boolean
	ComponentCompromised : Boolean
	void SafeGuardsDeactivateCompromisedSystem()
}
class SafeguardSystem  {
	SafeguardOnline : Boolean
	void SafeGuardsDeactivateCompromisedSystem()
}
class Monitor  {
	MonitorOnline : Boolean
	MonitorCompromised : Boolean
	MonitorOS : String
	MonitorSoftwareRelease : Integer
	MonitorInfected : Boolean
	SoftwarePresent : String
	IP : String
	void NetworkCompromised()
	void OperatorOpensPhishingEmail()
	void DeviceCompromisesNetwork()
	void MonitorInfectsPLC()
	void HackerSendsPhishingEmail()
}
class Any  {
}
class Actuator  {
	ActuatorOnline : Boolean
	ActuatorCompromised : Boolean
	void ReactorMotorDestroyed()
	void SafeGuardsDeactivateCompromisedSystem()
}
class Sensor  {
	SensorOnline : Boolean
	SensorCompromised : Boolean
}
class Operator  {
	PhishingEmailReceived : Boolean
	PhishingEmailOpened : Boolean
	Email : String
	TrustedEmails : String
	isHacker : Boolean
	void HackerSendsPhishingEmail()
	void OperatorOpensPhishingEmail()
}
class Malware  {
	OwnerIP : String
	CompatableSoftwareDate : Integer
	CompatableMonitorOS : String
	CompatablePLCOS : String
	RequiredSoftware : String
	void NetworkCompromised()
	void OperatorOpensPhishingEmail()
	void DeviceCompromisesNetwork()
	void MonitorInfectsPLC()
	void HackerSendsPhishingEmail()
}
class SensitiveFile  {
}
class Monitor  {
	MonitorOnline : Boolean
	MonitorCompromised : Boolean
	MonitorOS : String
	MonitorSoftwareRelease : Integer
	MonitorInfected : Boolean
	SoftwarePresent : String
	IP : String
	void DeviceCompromisesNetwork()
	void HackerSendsPhishingEmail()
	void OperatorOpensPhishingEmail()
	void MonitorInfectsPLC()
	void NetworkCompromised()
}
class PLC  {
	PLCOnline : Boolean
	PLCCompromised : Boolean
	PLCOS : String
	PLCSoftwareRelease : Integer
	PLCInfected : Boolean
	void MonitorInfectsPLC()
	void ReactorMotorDestroyed()
}
