@startuml
digraph Step1 {
	"begin" [shape = doublecircle];
	"end" [shape = doublecircle];
	edge [colorscheme = set19];
	edge [color = 1];
	"begin" -> "NetworkCompromised(Ethernet, ControlRoom, Stuxnet)" [label="0::0"];
	"NetworkCompromised(Ethernet, ControlRoom, Stuxnet)" -> "MonitorInfectsPLC(Ethernet, ControlRoom, ReactorController, Stuxnet)" [label="0::1"];
	"MonitorInfectsPLC(Ethernet, ControlRoom, ReactorController, Stuxnet)" -> "ReactorMotorDestroyed(ReactorActuator, ReactorController)" [label="0::2"];
	"ReactorMotorDestroyed(ReactorActuator, ReactorController)" -> "SafeGuardsDeactivateCompromisedSystem(SafeGuarding, ReactorActuator, Reactor)" [label="0::3"];
	"SafeGuardsDeactivateCompromisedSystem(SafeGuarding, ReactorActuator, Reactor)" -> "end" [label="0::4"];
	edge [color = 2];
	"begin" -> "NetworkCompromised(Ethernet, ControlRoom, Stuxnet)" [label="1::0"];
	"NetworkCompromised(Ethernet, ControlRoom, Stuxnet)" -> "MonitorInfectsPLC(Ethernet, ControlRoom, ReactorController, Stuxnet)" [label="1::1"];
	"MonitorInfectsPLC(Ethernet, ControlRoom, ReactorController, Stuxnet)" -> "ReactorMotorDestroyed(ReactorActuator, ReactorController)" [label="1::2"];
	"ReactorMotorDestroyed(ReactorActuator, ReactorController)" -> "SafeGuardsDeactivateCompromisedSystem(SafeGuarding, ReactorActuator, Reactor)" [label="1::3"];
	"SafeGuardsDeactivateCompromisedSystem(SafeGuarding, ReactorActuator, Reactor)" -> "end" [label="1::4"];
	{ rank = source; "begin"; }
	{ rank = sink; "end"; }
}
@enduml
