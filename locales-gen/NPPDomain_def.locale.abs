AssetBasedSystem
import "platform:/resource/lc2071HonoursProject/NPP Prototype/models/NPPDomain_def.abs";
Locale {
	locale = ""
	DefinitionGroup NPPDomain_def {
		AssetType NetworkConnector = "NetworkConnector" {
			description = "Connects two components together"
			attribute trafficLevel = "trafficLevel"
			attribute trafficCapacity = "trafficCapacity"
			attribute online = "online"
			attribute NetworkCompromised = "NetworkCompromised"
			reference PLCs = "PLCs"
			reference Monitors = "Monitors"
		}
		AssetType Monitor = "Monitor" {
			description = "Provides a high-level overview of component activity"
			attribute online = "online"
			attribute MonitorCompromised = "MonitorCompromised"
			attribute MonitorOS = "MonitorOS"
			attribute SoftwareRelease = "SoftwareRelease"
			attribute MonitorInfected = "MonitorInfected"
			reference SiblingMonitor = "SiblingMonitor"
			reference Connector = "Connector"
		}
		AssetType PLC = "PLC" {
			description = "Programmable logic controller- runs arbitrary code to control industrial components"
			attribute online = "online"
			attribute compromised = "compromised"
			attribute PLCOS = "PLCOS"
			attribute SoftwareRelease = "SoftwareRelease"
			attribute Infected = "Infected"
			reference Connector = "Connector"
			reference ChildActuator = "ChildActuator"
			reference ChildSensor = "ChildSensor"
		}
		AssetType IndustrialComponent = "IndustrialComponent" {
			description = "End Point Components i.e. turbines,steam generators etc."
			attribute online = "online"
			attribute compromised = "compromised"
			reference ParentSensor = "ParentSensor"
		}
		AssetType Actuator = "Actuator" {
			description = "receives a signal from the PLC to perform an action on the industrial component"
			attribute online = "online"
			attribute compromised = "compromised"
			reference ChildComponent = "ChildComponent"
		}
		AssetType Sensor = "Sensor" {
			description = "receives input from the industrial component and takes reading as to it's status"
			attribute online = "online"
			attribute compromised = "compromised"
			reference ChildComponent = "ChildComponent"
			reference ParentPLC = "ParentPLC"
		}
		AssetType Malware = "Malware" {
			description = "A malicious software existing on devices in an NPP network"
			attribute CompatableSoftwareDate = "CompatableSoftwareDate"
			attribute CompatableMonitorOS = "CompatableMonitorOS"
			attribute CompatablePLCOS = "CompatablePLCOS"
			reference InfectedMonitors = "InfectedMonitors"
		}
		AssetType SafeguardSystem = "SafeguardSystem" {
			description = "System responsible for automatic shutdown in the event of a catastrophe"
			attribute online = "online"
		}
	}
}
